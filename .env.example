# Copy to .env and paste your key:
#   copy .env.example .env

# OpenRouter (required for codecrafters submit)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq (optional, local only)
# GROQ_API_KEY=gsk-your-key-here
# GROQ_MODEL=openai/gpt-oss-120b

# Web search (optional — uses DuckDuckGo when unset)
# TAVILY_API_KEY=tvly-your-key-here
# BRAVE_SEARCH_API_KEY=your-brave-key-here

# MCP (optional — chat mode only; copy mcp.json.example to mcp.json)
# MCP_CONFIG=mcp.json
# MCP_DISABLE=1
